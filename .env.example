# MongoDB
# Atlas connection string from cloud.mongodb.com (include a database name)
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/genisis?retryWrites=true&w=majority
MONGO_URI=

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1d

# Groq vision API (required from phase 4 onward)
GROQ_API_KEY=
# Verify current vision model IDs at console.groq.com/docs/models
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Backend
PORT=3001
UPLOAD_DIR=/app/uploads

# Frontend (browser-reachable URL for API calls from the client)
NEXT_PUBLIC_API_URL=http://localhost:3001

NODE_ENV=development

# Seed (idempotent — safe to run multiple times)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=AdminPass1
